// Biogrow Platform — Prisma Schema
// Phase 1: Foundation  |  Phase 2: CRM Core  |  Phase 3: ERP Core

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT / COMPANY
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  type         CompanyType @default(COMPANY)
  parentId     String?     @map("parent_id")
  parent       Company?    @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children     Company[]   @relation("CompanyHierarchy")

  logoUrl      String?     @map("logo_url")
  primaryColor String?     @map("primary_color")
  timezone     String      @default("America/New_York")
  currency     String      @default("USD")
  modulesEnabled String[]  @default([]) @map("modules_enabled")

  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  memberships     UserCompanyMembership[]
  roles           Role[]
  auditLogs       AuditLog[]
  pipelineStages  PipelineStage[]
  leads           Lead[]
  accounts        Account[]
  contacts        Contact[]
  opportunities   Opportunity[]
  activities      Activity[]
  tasks           Task[]
  quotes          Quote[]

  // ERP
  productCategories  ProductCategory[]
  products           Product[]
  priceLists         PriceList[]
  vendors            Vendor[]
  warehouses         Warehouse[]
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  invoices           Invoice[]
  arLedger           ARLedger[]
  apLedger           APLedger[]
  cashFlowEntries    CashFlowEntry[]

  @@map("companies")
}

enum CompanyType {
  HOLDING
  COMPANY
  @@map("company_type")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id         String     @id @default(cuid())
  clerkId    String     @unique @map("clerk_id")
  email      String     @unique
  name       String
  avatarUrl  String?    @map("avatar_url")
  globalRole GlobalRole @default(MEMBER) @map("global_role")
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  memberships   UserCompanyMembership[]
  auditLogs     AuditLog[]
  ownedLeads    Lead[]        @relation("LeadOwner")
  ownedAccounts Account[]     @relation("AccountOwner")
  ownedContacts Contact[]     @relation("ContactOwner")
  ownedOpps     Opportunity[] @relation("OpportunityOwner")
  activities    Activity[]
  tasks         Task[]        @relation("TaskOwner")
  assignedTasks Task[]        @relation("TaskAssignee")
  quotes        Quote[]
  salesOrders   SalesOrder[]
  purchaseOrders PurchaseOrder[]
  inventoryMovements InventoryMovement[]
  invoices      Invoice[]

  @@map("users")
}

enum GlobalRole {
  SUPERADMIN
  HOLDING_ADMIN
  HOLDING_EXEC
  MEMBER
  @@map("global_role")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBERSHIP / ROLES / PERMISSIONS
// ─────────────────────────────────────────────────────────────────────────────

model UserCompanyMembership {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  roleId    String   @map("role_id")
  isPrimary Boolean  @default(false) @map("is_primary")
  isActive  Boolean  @default(true) @map("is_active")
  joinedAt  DateTime @default(now()) @map("joined_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@map("user_company_memberships")
}

model Role {
  id          String   @id @default(cuid())
  companyId   String?  @map("company_id")
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  permissions RolePermission[]
  memberships UserCompanyMembership[]

  @@unique([companyId, name])
  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  module      String
  entity      String
  action      String
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String?  @map("company_id")
  company    Company? @relation(fields: [companyId], references: [id])
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([companyId, entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — PIPELINE
// ─────────────────────────────────────────────────────────────────────────────

model PipelineStage {
  id          String  @id @default(cuid())
  companyId   String  @map("company_id")
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  order       Int
  probability Int     @default(0)   // 0–100 percentage
  color       String  @default("#6b7280")
  isWon       Boolean @default(false) @map("is_won")
  isLost      Boolean @default(false) @map("is_lost")
  isDefault   Boolean @default(false) @map("is_default")

  opportunities Opportunity[]

  @@unique([companyId, name])
  @@index([companyId, order])
  @@map("pipeline_stages")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — LEAD
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id        String     @id @default(cuid())
  companyId String     @map("company_id")
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId   String     @map("owner_id")
  owner     User       @relation("LeadOwner", fields: [ownerId], references: [id])

  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  email       String?
  phone       String?
  companyName String? @map("company_name")
  jobTitle    String? @map("job_title")
  website     String?

  source      LeadSource @default(OTHER)
  status      LeadStatus @default(NEW)
  score       Int        @default(0)
  description String?

  // Conversion tracking
  convertedAt             DateTime? @map("converted_at")
  convertedToAccountId    String?   @map("converted_to_account_id")
  convertedToContactId    String?   @map("converted_to_contact_id")
  convertedToOpportunityId String?  @map("converted_to_opportunity_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities Activity[]
  tasks      Task[]

  @@index([companyId, status])
  @@index([companyId, ownerId])
  @@index([companyId, createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  @@map("lead_status")
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_OUTREACH
  EVENT
  SOCIAL_MEDIA
  PAID_ADS
  EMAIL_CAMPAIGN
  PARTNER
  OTHER
  @@map("lead_source")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — ACCOUNT
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id        String      @id @default(cuid())
  companyId String      @map("company_id")
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId   String      @map("owner_id")
  owner     User        @relation("AccountOwner", fields: [ownerId], references: [id])

  name           String
  type           AccountType @default(PROSPECT)
  industry       String?
  website        String?
  phone          String?
  email          String?
  annualRevenue  Float?  @map("annual_revenue")
  employeeCount  Int?    @map("employee_count")
  description    String?
  healthScore    Int     @default(50) @map("health_score") // 0–100

  // Address
  street   String?
  city     String?
  state    String?
  country  String?
  zip      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contacts      Contact[]
  opportunities Opportunity[]
  activities    Activity[]
  tasks         Task[]
  quotes        Quote[]
  salesOrders   SalesOrder[]
  invoices      Invoice[]
  arLedger      ARLedger[]

  @@index([companyId, ownerId])
  @@index([companyId, type])
  @@map("accounts")
}

enum AccountType {
  PROSPECT
  CUSTOMER
  PARTNER
  VENDOR
  CHURNED
  @@map("account_type")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — CONTACT
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId   String  @map("owner_id")
  owner     User    @relation("ContactOwner", fields: [ownerId], references: [id])
  accountId String? @map("account_id")
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  firstName  String  @map("first_name")
  lastName   String  @map("last_name")
  email      String?
  phone      String?
  mobile     String?
  jobTitle   String? @map("job_title")
  department String?
  isPrimary  Boolean @default(false) @map("is_primary")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  opportunities Opportunity[]
  activities    Activity[]
  tasks         Task[]

  @@index([companyId, accountId])
  @@index([companyId, ownerId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — OPPORTUNITY
// ─────────────────────────────────────────────────────────────────────────────

model Opportunity {
  id        String        @id @default(cuid())
  companyId String        @map("company_id")
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId   String        @map("owner_id")
  owner     User          @relation("OpportunityOwner", fields: [ownerId], references: [id])
  accountId String?       @map("account_id")
  account   Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  contactId String?       @map("contact_id")
  contact   Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  stageId   String        @map("stage_id")
  stage     PipelineStage @relation(fields: [stageId], references: [id])

  name             String
  amount           Float  @default(0)
  currency         String @default("USD")
  probability      Int    @default(0)   // 0–100, overrides stage probability if set
  forecastCategory ForecastCategory @default(PIPELINE) @map("forecast_category")

  expectedCloseDate DateTime? @map("expected_close_date")
  closedAt          DateTime? @map("closed_at")
  lostReason        String?   @map("lost_reason")
  description       String?
  nextStep          String?   @map("next_step")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activities Activity[]
  tasks      Task[]
  quotes     Quote[]

  @@index([companyId, stageId])
  @@index([companyId, ownerId])
  @@index([companyId, forecastCategory])
  @@index([companyId, expectedCloseDate])
  @@map("opportunities")
}

enum ForecastCategory {
  PIPELINE
  BEST_CASE
  COMMIT
  CLOSED_WON
  CLOSED_LOST
  OMITTED
  @@map("forecast_category")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — ACTIVITY
// Activity is polymorphic: links to Lead, Account, Contact, or Opportunity
// ─────────────────────────────────────────────────────────────────────────────

model Activity {
  id        String       @id @default(cuid())
  companyId String       @map("company_id")
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id])

  type      ActivityType
  subject   String
  body      String?
  outcome   String?
  occurredAt  DateTime   @default(now()) @map("occurred_at")
  durationMin Int?       @map("duration_min")

  // Polymorphic links (one of these will be set)
  leadId        String?  @map("lead_id")
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  accountId     String?  @map("account_id")
  account       Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId     String?  @map("contact_id")
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?  @map("opportunity_id")
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, userId])
  @@index([companyId, occurredAt])
  @@index([leadId])
  @@index([accountId])
  @@index([contactId])
  @@index([opportunityId])
  @@map("activities")
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK_COMPLETED
  STAGE_CHANGE
  @@map("activity_type")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — TASK
// ─────────────────────────────────────────────────────────────────────────────

model Task {
  id         String      @id @default(cuid())
  companyId  String      @map("company_id")
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId    String      @map("owner_id")
  owner      User        @relation("TaskOwner", fields: [ownerId], references: [id])
  assigneeId String?     @map("assignee_id")
  assignee   User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])

  title       String
  description String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  completedAt DateTime?    @map("completed_at")

  // Polymorphic
  leadId        String?  @map("lead_id")
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  accountId     String?  @map("account_id")
  account       Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId     String?  @map("contact_id")
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunityId String?  @map("opportunity_id")
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, ownerId, status])
  @@index([companyId, dueDate])
  @@map("tasks")
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  @@map("task_status")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  @@map("task_priority")
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — QUOTE
// ─────────────────────────────────────────────────────────────────────────────

model Quote {
  id            String      @id @default(cuid())
  companyId     String      @map("company_id")
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId       String      @map("owner_id")
  owner         User        @relation(fields: [ownerId], references: [id])
  accountId     String?     @map("account_id")
  account       Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  opportunityId String?     @map("opportunity_id")
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  number       String      // e.g. Q-2024-0001
  status       QuoteStatus @default(DRAFT)
  currency     String      @default("USD")
  subtotal     Float       @default(0)
  discountPct  Float       @default(0) @map("discount_pct")
  taxPct       Float       @default(0) @map("tax_pct")
  total        Float       @default(0)

  validUntil   DateTime?   @map("valid_until")
  notes        String?
  terms        String?
  sentAt       DateTime?   @map("sent_at")
  acceptedAt   DateTime?   @map("accepted_at")
  rejectedAt   DateTime?   @map("rejected_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lineItems QuoteLineItem[]

  @@index([companyId, status])
  @@index([companyId, ownerId])
  @@map("quotes")
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description String
  quantity    Float   @default(1)
  unitPrice   Float   @map("unit_price")
  discountPct Float   @default(0) @map("discount_pct")
  total       Float

  sortOrder   Int     @default(0) @map("sort_order")

  @@index([quoteId])
  @@map("quote_line_items")
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  @@map("quote_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP — PRODUCT CATALOG
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  parentId    String?  @map("parent_id")
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")

  products    Product[]

  @@unique([companyId, name])
  @@map("product_categories")
}

model Product {
  id          String      @id @default(cuid())
  companyId   String      @map("company_id")
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId  String?     @map("category_id")
  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sku         String?
  name        String
  description String?
  type        ProductType @default(SERVICE)
  unit        String      @default("unit")  // unit, kg, lt, hr, etc.

  basePrice   Float       @default(0) @map("base_price")
  currency    String      @default("USD")
  taxPct      Float       @default(0) @map("tax_pct")

  isActive    Boolean     @default(true) @map("is_active")
  imageUrl    String?     @map("image_url")

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  priceListItems       PriceListItem[]
  stockItems           StockItem[]
  inventoryMovements   InventoryMovement[]
  salesOrderLineItems  SalesOrderLineItem[]
  purchaseOrderLineItems PurchaseOrderLineItem[]
  invoiceLineItems     InvoiceLineItem[]

  @@unique([companyId, sku])
  @@index([companyId, type])
  @@index([companyId, categoryId])
  @@map("products")
}

enum ProductType {
  PHYSICAL    // physical goods tracked in inventory
  SERVICE     // services not tracked in inventory
  DIGITAL     // digital goods
  @@map("product_type")
}

model PriceList {
  id          String    @id @default(cuid())
  companyId   String    @map("company_id")
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  currency    String    @default("USD")
  isDefault   Boolean   @default(false) @map("is_default")
  validFrom   DateTime? @map("valid_from")
  validTo     DateTime? @map("valid_to")
  isActive    Boolean   @default(true) @map("is_active")

  items       PriceListItem[]

  @@unique([companyId, name])
  @@map("price_lists")
}

model PriceListItem {
  id           String    @id @default(cuid())
  priceListId  String    @map("price_list_id")
  priceList    PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId    String    @map("product_id")
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  price        Float
  minQuantity  Float     @default(1) @map("min_quantity")

  @@unique([priceListId, productId])
  @@map("price_list_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP — VENDORS
// ─────────────────────────────────────────────────────────────────────────────

model Vendor {
  id          String       @id @default(cuid())
  companyId   String       @map("company_id")
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name            String
  legalName       String?  @map("legal_name")
  taxId           String?  @map("tax_id")
  email           String?
  phone           String?
  website         String?
  status          VendorStatus @default(ACTIVE)

  // Contact person
  contactName     String?  @map("contact_name")
  contactEmail    String?  @map("contact_email")
  contactPhone    String?  @map("contact_phone")

  // Address
  street          String?
  city            String?
  state           String?
  country         String?
  zip             String?

  // Payment terms
  paymentTermsDays Int?    @default(30) @map("payment_terms_days")
  currency         String  @default("USD")
  notes            String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]
  apLedger       APLedger[]

  @@index([companyId, status])
  @@map("vendors")
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  @@map("vendor_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP — INVENTORY (Phase 3B)
// ─────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  code        String?
  address     String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true)  @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  stockItems  StockItem[]
  movements   InventoryMovement[]

  @@unique([companyId, name])
  @@map("warehouses")
}

model StockItem {
  id           String    @id @default(cuid())
  warehouseId  String    @map("warehouse_id")
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId    String    @map("product_id")
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity     Float     @default(0)
  reservedQty  Float     @default(0) @map("reserved_qty")
  minStock     Float?    @map("min_stock")
  maxStock     Float?    @map("max_stock")

  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([warehouseId, productId])
  @@map("stock_items")
}

model InventoryMovement {
  id          String            @id @default(cuid())
  companyId   String            @map("company_id")
  warehouseId String            @map("warehouse_id")
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])
  productId   String            @map("product_id")
  product     Product           @relation(fields: [productId], references: [id])
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id])

  type        MovementType
  quantity    Float             // positive = in, negative = out
  unitCost    Float?            @map("unit_cost")
  reference   String?           // PO number, SO number, adjustment ref
  notes       String?
  occurredAt  DateTime          @default(now()) @map("occurred_at")

  @@index([companyId, productId])
  @@index([warehouseId, occurredAt])
  @@map("inventory_movements")
}

enum MovementType {
  PURCHASE_RECEIPT   // from purchase order
  SALE_SHIPMENT      // from sales order
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN_IN
  RETURN_OUT
  @@map("movement_type")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP — SALES ORDERS (Phase 3C)
// ─────────────────────────────────────────────────────────────────────────────

model SalesOrder {
  id          String          @id @default(cuid())
  companyId   String          @map("company_id")
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId     String          @map("owner_id")
  owner       User            @relation(fields: [ownerId], references: [id])
  quoteId     String?         @map("quote_id")   // source quote (optional)
  accountId   String?         @map("account_id")
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)

  number          String       // SO-YYYY-NNNN
  status          SalesOrderStatus @default(DRAFT)
  currency        String       @default("USD")
  subtotal        Float        @default(0)
  discountPct     Float        @default(0) @map("discount_pct")
  taxPct          Float        @default(0) @map("tax_pct")
  total           Float        @default(0)

  shippingAddress String?      @map("shipping_address")
  requestedDate   DateTime?    @map("requested_date")
  shippedAt       DateTime?    @map("shipped_at")
  deliveredAt     DateTime?    @map("delivered_at")
  notes           String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  lineItems   SalesOrderLineItem[]
  invoices    Invoice[]

  @@index([companyId, status])
  @@index([companyId, ownerId])
  @@map("sales_orders")
}

model SalesOrderLineItem {
  id           String     @id @default(cuid())
  salesOrderId String     @map("sales_order_id")
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String?    @map("product_id")
  product      Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  description  String
  quantity     Float      @default(1)
  unitPrice    Float      @map("unit_price")
  discountPct  Float      @default(0) @map("discount_pct")
  total        Float
  sortOrder    Int        @default(0) @map("sort_order")

  @@index([salesOrderId])
  @@map("sales_order_line_items")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  @@map("sales_order_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP — PURCHASE ORDERS (Phase 3D)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id          String              @id @default(cuid())
  companyId   String              @map("company_id")
  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId     String              @map("owner_id")
  owner       User                @relation(fields: [ownerId], references: [id])
  vendorId    String              @map("vendor_id")
  vendor      Vendor              @relation(fields: [vendorId], references: [id])

  number        String             // PO-YYYY-NNNN
  status        PurchaseOrderStatus @default(DRAFT)
  currency      String             @default("USD")
  subtotal      Float              @default(0)
  taxPct        Float              @default(0) @map("tax_pct")
  total         Float              @default(0)

  expectedDate  DateTime?          @map("expected_date")
  receivedAt    DateTime?          @map("received_at")
  approvedAt    DateTime?          @map("approved_at")
  approvedById  String?            @map("approved_by_id")
  notes         String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  lineItems   PurchaseOrderLineItem[]
  apLedger    APLedger[]

  @@index([companyId, status])
  @@index([companyId, vendorId])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id              String        @id @default(cuid())
  purchaseOrderId String        @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?       @map("product_id")
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  description     String
  quantity        Float         @default(1)
  unitCost        Float         @map("unit_cost")
  total           Float
  receivedQty     Float         @default(0) @map("received_qty")
  sortOrder       Int           @default(0) @map("sort_order")

  @@index([purchaseOrderId])
  @@map("purchase_order_line_items")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  @@map("purchase_order_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// ERP — FINANCE (Phase 3E)
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id           String        @id @default(cuid())
  companyId    String        @map("company_id")
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId      String        @map("owner_id")
  owner        User          @relation(fields: [ownerId], references: [id])
  salesOrderId String?       @map("sales_order_id")
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  accountId    String?       @map("account_id")
  account      Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  number       String         // INV-YYYY-NNNN
  status       InvoiceStatus  @default(DRAFT)
  currency     String         @default("USD")
  subtotal     Float          @default(0)
  taxPct       Float          @default(0) @map("tax_pct")
  taxAmount    Float          @default(0) @map("tax_amount")
  total        Float          @default(0)
  paidAmount   Float          @default(0) @map("paid_amount")

  issuedAt     DateTime?      @map("issued_at")
  dueDate      DateTime?      @map("due_date")
  paidAt       DateTime?      @map("paid_at")
  voidedAt     DateTime?      @map("voided_at")
  notes        String?

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  lineItems    InvoiceLineItem[]
  arLedger     ARLedger[]

  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String? @map("product_id")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  description String
  quantity    Float   @default(1)
  unitPrice   Float   @map("unit_price")
  total       Float
  sortOrder   Int     @default(0) @map("sort_order")

  @@index([invoiceId])
  @@map("invoice_line_items")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  @@map("invoice_status")
}

model ARLedger {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId   String   @map("invoice_id")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  accountId   String?  @map("account_id")
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  amount      Float
  type        LedgerEntryType
  reference   String?
  notes       String?
  entryDate   DateTime @default(now()) @map("entry_date")

  @@index([companyId, entryDate])
  @@index([invoiceId])
  @@map("ar_ledger")
}

model APLedger {
  id              String        @id @default(cuid())
  companyId       String        @map("company_id")
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrderId String?       @map("purchase_order_id")
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  vendorId        String        @map("vendor_id")
  vendor          Vendor        @relation(fields: [vendorId], references: [id])

  amount      Float
  type        LedgerEntryType
  reference   String?
  notes       String?
  dueDate     DateTime?        @map("due_date")
  paidAt      DateTime?        @map("paid_at")
  entryDate   DateTime         @default(now()) @map("entry_date")

  @@index([companyId, entryDate])
  @@index([vendorId])
  @@map("ap_ledger")
}

enum LedgerEntryType {
  CHARGE
  PAYMENT
  CREDIT
  ADJUSTMENT
  @@map("ledger_entry_type")
}

model CashFlowEntry {
  id          String            @id @default(cuid())
  companyId   String            @map("company_id")
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type        CashFlowType
  category    String            // e.g. "sales", "payroll", "supplier", "tax"
  description String
  amount      Float             // positive = inflow, negative = outflow
  currency    String            @default("USD")
  entryDate   DateTime          @map("entry_date")
  reference   String?

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([companyId, entryDate])
  @@index([companyId, type])
  @@map("cash_flow_entries")
}

enum CashFlowType {
  INFLOW
  OUTFLOW
  @@map("cash_flow_type")
}
